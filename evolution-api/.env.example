# === Evolution API .env ===

SERVER_TYPE=http
SERVER_PORT=8080
SERVER_URL=http://localhost:8080

# Auth
AUTHENTICATION_API_KEY=your_api_key_here
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=true

# Log
LOG_LEVEL=ERROR
LOG_COLOR=true
DEL_INSTANCE=false

# Postgres
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:your_password@evolution-postgres:5432/evolution_db?schema=public

# Redis (cache)
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://evolution-redis:6379/1
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_REDIS_SAVE_INSTANCES=false
CACHE_LOCAL_ENABLED=false

# Chatwoot integration
CHATWOOT_ENABLED=true
CHATWOOT_MESSAGE_READ=true
CHATWOOT_MESSAGE_DELETE=true
CHATWOOT_IMPORT_DATABASE_CONNECTION_URI=postgresql://postgres:your_chatwoot_pg_password@chatwoot-postgres-1:5432/chatwoot_production?sslmode=disable
CHATWOOT_IMPORT_PLACEHOLDER_MEDIA_MESSAGE=true
