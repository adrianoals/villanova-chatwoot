# =============================================================================
# Evolution API — production .env template
# =============================================================================
# Como usar:
#   cp .env.example .env
#   # Edite os valores marcados como CHANGE_ME
# Nunca comite o .env real (já está no .gitignore).

# ---- Server ----
SERVER_TYPE=http
SERVER_PORT=8080
SERVER_URL=https://evo.villanovacondominios.com.br

# ---- Auth (API Key Global — usada no header `apikey` em todas as requests) ----
# Gerar com: openssl rand -base64 32 | tr -d '/+=' | head -c 40
AUTHENTICATION_API_KEY=CHANGE_ME_API_KEY
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=true

# ---- Log ----
LOG_LEVEL=ERROR
LOG_COLOR=false
DEL_INSTANCE=false

# ---- Postgres (interno do stack) ----
POSTGRES_DB=evolution_db
POSTGRES_USER=evolution
# Gerar com: openssl rand -base64 24 | tr -d '/+=' | head -c 32
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
# Manter a senha igual a POSTGRES_PASSWORD acima
DATABASE_CONNECTION_URI=postgresql://evolution:CHANGE_ME_POSTGRES_PASSWORD@evolution-postgres:5432/evolution_db?schema=public

# ---- Redis (cache, interno) ----
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://evolution-redis:6379/1
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_REDIS_SAVE_INSTANCES=false
CACHE_LOCAL_ENABLED=false

# ---- Chatwoot integration ----
CHATWOOT_ENABLED=true
CHATWOOT_MESSAGE_READ=true
CHATWOOT_MESSAGE_DELETE=true

# Workaround Evolution v2.3.7: o default hardcoded da URI tem hostname literal "host" e
# typo na senha ("passwprd"), fazendo isImportHistoryAvailable() retornar true e quebrar
# o source_id update em toda mensagem outbound (status fica como "Falha ao enviar" no Chatwoot).
# Setar como o placeholder EXATO que a função verifica força ela a retornar false e desativa
# o método bugado. Quando a Evolution lançar fix oficial, remover esta linha.
CHATWOOT_IMPORT_DATABASE_CONNECTION_URI=postgres://user:password@hostname:port/dbname
