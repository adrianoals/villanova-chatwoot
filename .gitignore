# Environment variables (contain secrets)
.env
*.env
chatwoot/.env
evolution/.env

# Traefik Let's Encrypt cert storage (regenerated on first run, but losing
# acme.json mid-flight hits Let's Encrypt rate limits)
traefik/letsencrypt/

# Docker volumes and data
postgres_data/
redis_data/
storage_data/

# Local-only artifacts
*.bak

# Backups
*.sql
*.sql.gz
backups/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Node
node_modules/

# Python
__pycache__/
*.pyc
.venv/
venv/

# Logs
*.log

# Temporary files
/tmp/
*.tmp
