# =============================================================================
# Chatwoot — production .env template
# =============================================================================
# Como usar:
#   cp .env.example .env
#   # Edite os valores marcados como CHANGE_ME
# Nunca comite o .env real (já está no .gitignore).

# ---- Core ----
# Gerar com: openssl rand -hex 64
SECRET_KEY_BASE=CHANGE_ME_64_HEX_CHARS

# URL pública (a que vai no Traefik label e no browser dos atendentes)
FRONTEND_URL=https://multi-chat.villanovacondominios.com.br

DEFAULT_LOCALE=pt_BR
FORCE_SSL=true
ENABLE_ACCOUNT_SIGNUP=false

# ---- Postgres (interno do stack) ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=chatwoot_production
POSTGRES_USERNAME=postgres
# Gerar com: openssl rand -base64 24 | tr -d '/+=' | head -c 32
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# ---- Redis (interno do stack) ----
# Gerar com: openssl rand -base64 24 | tr -d '/+=' | head -c 32
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379

# ---- Storage (uploads, anexos) ----
ACTIVE_STORAGE_SERVICE=local

# ---- Rails ----
RAILS_ENV=production
NODE_ENV=production
INSTALLATION_ENV=docker
RAILS_LOG_TO_STDOUT=true
LOG_LEVEL=info
RAILS_MAX_THREADS=5

# ---- SMTP (necessário pra convites de agente, password reset, notificações) ----
MAILER_SENDER_EMAIL=noreply@villanovacondominios.com.br
SMTP_DOMAIN=villanovacondominios.com.br
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=login
SMTP_ENABLE_STARTTLS_AUTO=true
